<?xml version="1.0" encoding="UTF-8"?>
<entity-mappings
        xmlns="https://jakarta.ee/xml/ns/persistence/orm"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence/orm
                            https://jakarta.ee/xml/ns/persistence/orm/orm_3_1.xsd"
        version="3.1">

    <entity class="allmart.deliveryservice.domain.delivery.Delivery" access="FIELD">
        <table name="deliveries">
            <index name="idx_delivery_order_id" column-list="order_id"/>
            <index name="idx_delivery_buyer_id" column-list="buyer_id"/>
        </table>
        <attributes>
            <basic name="orderId">
                <column name="order_id" nullable="false" updatable="false"/>
            </basic>
            <basic name="buyerId">
                <column name="buyer_id" nullable="false" updatable="false"/>
            </basic>
            <basic name="totalAmount">
                <column name="total_amount" nullable="false"/>
            </basic>
            <basic name="status">
                <column name="status" nullable="false" length="20"/>
                <enumerated>STRING</enumerated>
            </basic>
            <basic name="receiverName">
                <column name="receiver_name" nullable="false" length="50"/>
            </basic>
            <basic name="receiverPhone">
                <column name="receiver_phone" nullable="false" length="20"/>
            </basic>
            <basic name="zipCode">
                <column name="zip_code" nullable="false" length="10"/>
            </basic>
            <basic name="address">
                <column name="address" nullable="false" length="200"/>
            </basic>
            <basic name="detailAddress">
                <column name="detail_address" nullable="false" length="200"/>
            </basic>
            <basic name="createdAt">
                <column name="created_at" updatable="false"/>
            </basic>
            <basic name="deliveredAt">
                <column name="delivered_at"/>
            </basic>
        </attributes>
    </entity>

    <entity class="allmart.deliveryservice.domain.event.OutboxEvent" access="FIELD">
        <table name="outbox_event">
            <index name="idx_outbox_created_at" column-list="created_at"/>
        </table>
        <attributes>
            <basic name="eventType">
                <column name="event_type" nullable="false" length="50"/>
            </basic>
            <basic name="aggregateId">
                <column name="aggregate_id" nullable="false" length="100"/>
            </basic>
            <basic name="aggregateType">
                <column name="aggregate_type" nullable="false" length="50"/>
            </basic>
            <basic name="payload">
                <column name="payload" nullable="false" column-definition="MEDIUMTEXT"/>
                <lob/>
            </basic>
            <basic name="createdAt">
                <column name="created_at" nullable="false" updatable="false"/>
            </basic>
        </attributes>
    </entity>

</entity-mappings>